# ============================================
# FOODIO API - Production Environment Configuration
# ============================================
# 
# Copy this file to .env in your project root
# Fill in all required values marked with [REQUIRED]
# Update optional values as needed for your environment
#
# CRITICAL: Never commit .env file to version control!
# Add .env to .gitignore immediately
#
# ============================================

# ============================================
# APPLICATION CONFIGURATION [REQUIRED]
# ============================================
# Node environment: development, production, staging
NODE_ENV=production

# Server port
PORT=3000

# Application name
APP_NAME=FOODIO

# Public URL of your application
APP_URL=http://localhost:3000

# ============================================
# DATABASE CONFIGURATION [REQUIRED]
# ============================================
# MySQL Connection Details
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=9458
DB_NAME=foodio
DB_PORT=3307

# Database Connection Pool Settings
# Number of connections to maintain in pool
DB_POOL_SIZE=10

# Number of waiting connections before rejecting
DB_POOL_ACQUIRE_TIMEOUT=30000

# Max idle time before connection closes (ms)
DB_CONNECTION_IDLE_TIMEOUT=28800000

# Connection timeout (ms)
DB_CONNECTION_TIMEOUT=10000

# ============================================
# REDIS CACHE CONFIGURATION [REQUIRED]
# ============================================
# Redis Connection Details
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Connection Settings
REDIS_RETRY_STRATEGY_INTERVAL=100
REDIS_OFFLINE_QUEUE=true

# Cache TTL Settings (in seconds)
CACHE_TTL_PROFILE=3600
CACHE_TTL_RESTAURANT=1800
CACHE_TTL_MENU=1800
CACHE_TTL_ORDER=600
CACHE_TTL_WISHLIST=1800

# ============================================
# JWT AUTHENTICATION [REQUIRED]
# ============================================
# JWT Secret Key - MUST be minimum 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_required_change_this

# JWT Token Expiration
JWT_EXPIRY=24h

# JWT Algorithm
JWT_ALGORITHM=HS256

# ============================================
# EMAIL CONFIGURATION [REQUIRED]
# ============================================
# Gmail Configuration
MAIL=your-email@gmail.com

# Google App-Specific Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/app-passwords
# Requires 2-Factor Authentication enabled
MAIL_PASSWORD=your_app_specific_password_here

# Admin Email for Notifications
ADMIN_EMAIL=admin@foodio.com

# Email Service
MAIL_SERVICE=Gmail

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Upload Directory
UPLOAD_DIR=./uploads

# Maximum File Size (in bytes)
# Default: 10485760 = 10MB
MAX_FILE_SIZE=10485760

# Allowed MIME Types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf

# File Upload Path Prefix
UPLOAD_PATH_PREFIX=/uploads

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================
# Global Rate Limit
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=30

# Login Endpoint Rate Limiting
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# OTP Endpoint Rate Limiting
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MS=60000

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed Origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Allow Credentials
CORS_CREDENTIALS=true

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Log Level: ERROR, WARN, INFO, DEBUG, TRACE
LOG_LEVEL=INFO

# Log Directory
LOG_DIR=./logs

# ============================================
# VALIDATION CONFIGURATION
# ============================================
# Password Validation
MIN_PASSWORD_LENGTH=8

# Phone Validation
MIN_PHONE_LENGTH=10

# Name Validation
MIN_NAME_LENGTH=2
MAX_NAME_LENGTH=100

# Email Validation Pattern
EMAIL_PATTERN=^[^\s@]+@[^\s@]+\.[^\s@]+$

# ============================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================
# Razorpay Configuration (Optional)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Payment Success Callback URL
PAYMENT_CALLBACK_URL=https://yourdomain.com/api/payment/callback

# ============================================
# GOOGLE OAUTH2 CONFIGURATION
# ============================================
# Google OAuth Client ID
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Google OAuth Callback URL
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ============================================
# PRODUCTION DEPLOYMENT SETTINGS
# ============================================
# Enable HTTPS (set to true in production)
FORCE_HTTPS=false

# Trust Proxy (for load balancers)
TRUST_PROXY=1

# Session Settings (if applicable)
SESSION_SECRET=your_session_secret_here

# ============================================
# DATABASE BACKUP CONFIGURATION
# ============================================
# Backup Directory
BACKUP_DIR=./backups

# Backup Frequency (in days)
BACKUP_FREQUENCY=1

# ============================================
# SECURITY SETTINGS
# ============================================
# Helmet Security Headers
HELMET_CONTENT_SECURITY_POLICY=true
HELMET_STRICT_TRANSPORT_SECURITY=true

# API Key for Admin Operations (Optional)
ADMIN_API_KEY=your_secure_admin_api_key_here

# ============================================
# MONITORING & DEBUGGING
# ============================================
# Enable Request Logging
REQUEST_LOGGING=true

# Enable Stack Traces (set to false in production)
SHOW_STACK_TRACES=false

# Sentry DSN (Error Tracking - Optional)
SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
# Enable User Registration
ENABLE_REGISTRATION=true

# Enable Google Login
ENABLE_GOOGLE_LOGIN=false

# Enable Razorpay Payments
ENABLE_RAZORPAY=false

# ============================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================
# 1. Change NODE_ENV to "production"
# 2. Use strong JWT_SECRET (minimum 32 characters)
# 3. Configure database with replication/backup
# 4. Set up Redis sentinel for high availability
# 5. Enable FORCE_HTTPS when using SSL/TLS
# 6. Configure domain-specific ALLOWED_ORIGINS
# 7. Set up email service (Gmail/SendGrid/etc)
# 8. Configure Razorpay for payments
# 9. Enable monitoring/logging aggregation
# 10. Review security headers in Helmet configuration
# 11. Set up automated database backups
# 12. Configure process manager (PM2/systemd)
# 13. Set up CI/CD pipeline for deployments
# 14. Enable rate limiting and request throttling
# 15. Test graceful shutdown and health checks
JWT_EXPIRY=24h

# Email verification link expiry (seconds)
EMAIL_VERIFICATION_EXPIRY=86400

# OTP expiry (seconds)
OTP_EXPIRY=600

# Password reset token expiry (seconds)
RESET_TOKEN_EXPIRY=900

# ============================================
# SECURITY CONFIGURATION
# ============================================
# HTTPS only cookies (set to true in production)
HTTPS_ONLY=false

# Session cookie name
SESSION_COOKIE_NAME=foodio_session

# ============================================
# DEVELOPMENT ONLY
# ============================================
# DEBUG mode (enable console logging)
DEBUG=false

# Skip email verification (development only)
SKIP_EMAIL_VERIFICATION=false
