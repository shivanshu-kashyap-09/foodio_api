{
  "name": "foodio-api",
  "version": "1.0.0",
  "description": "FOODIO API - Production-ready food delivery platform",
  "keywords": [
    "food",
    "delivery",
    "REST API",
    "Express",
    "MySQL",
    "Redis",
    "payment-gateway",
    "authentication"
  ],
  "license": "ISC",
  "author": "FOODIO Development Team",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
  "swagger": "node ./src/config/swagger.js",
    "start": "nodemon index.js",
    "dev": "nodemon index.js",
    "dev:watch": "nodemon --legacy-watch index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "production": "NODE_ENV=production node index.js"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "groq-sdk": "^0.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "razorpay": "^2.9.2",
    "redis": "^5.11.0",
    "socket.io": "^4.7.2",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.3",
    "trim-request": "^1.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.6.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
